# Discord bot token (Developer Portal > Bot > Reset Token)
DISCORD_TOKEN=

# Application/Client ID (Developer Portal > General Information)
CLIENT_ID=

# Guild ID to deploy commands to instantly during development.
# Leave empty to deploy globally instead (takes up to 1 hour to propagate).
GUILD_ID=

# Channel ID where flight log submissions should be posted for review
FLIGHT_LOG_CHANNEL_ID=
